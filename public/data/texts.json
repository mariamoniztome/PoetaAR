  "poems": [
    {
      "id": "poem-1",
      "title": "Oceano de Madeira",
      "verses": [
        "As ondas são de carvalho,",
        "O sal é pó de lixa,",
        "Navego num barco de entalho,",
        "Onde a alma se fixa."
      ],
      "marker": {
        "roman": "I",
        "label": "O Mar",
        "qrCode": "/scene/sea"
      }
    },
    {
      "id": "poem-2",
      "title": "Jardim de Serragem",
      "verses": [
        "Flores de pinho e cedro,",
        "Crescem no chão da oficina,",
        "Onde o medo eu desmedro,",
        "E a vida se ilumina."
      ],
      "marker": {
        "roman": "II",
        "label": "O Campo",
        "qrCode": "/scene/field"
      }
    },
    {
      "id": "poem-3",
      "title": "Céu de Verniz",
      "verses": [
        "Pássaros de faia voam,",
        "Nuvens de algodão e cola,",
        "As vozes do vento ecoam,",
        "Nesta imensa gaiola."
      ],
      "marker": {
        "roman": "III",
        "label": "O Céu",
        "qrCode": "/scene/sky"
      }
    }
